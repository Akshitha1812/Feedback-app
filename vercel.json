{
    "version": 2,
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/client/$1"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/dashboard",
            "permanent": true
        }
    ]
}